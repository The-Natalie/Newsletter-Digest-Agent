# =============================================================================
# Newsletter Digest Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and replace the placeholder values with your own.
# Never commit .env to version control — it contains credentials.
# =============================================================================


# -----------------------------------------------------------------------------
# IMAP — Email Access
# -----------------------------------------------------------------------------
# Connection settings for your email provider's IMAP server.
# Use an App Password, not your main account password.
#
# Common IMAP hosts:
#   Gmail:    imap.gmail.com        port 993
#   Outlook:  outlook.office365.com port 993
#   Yahoo:    imap.mail.yahoo.com   port 993
#   Fastmail: imap.fastmail.com     port 993

IMAP_HOST=your-imap-host-here
IMAP_PORT=993
IMAP_USERNAME=your-email@example.com
IMAP_PASSWORD=your-app-password-here


# -----------------------------------------------------------------------------
# Claude API
# -----------------------------------------------------------------------------
# Your Anthropic API key. Get one at https://console.anthropic.com
#
# CLAUDE_MODEL controls which model generates the digest.
#   claude-haiku-4-5   — fast and cost-efficient (recommended)
#   claude-sonnet-4-6  — higher quality, higher cost

ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-haiku-4-5


# -----------------------------------------------------------------------------
# Pipeline Tuning
# -----------------------------------------------------------------------------
# MAX_EMAILS_PER_RUN: maximum number of emails processed in a single digest run.
# Prevents unexpectedly large API bills on catch-up runs covering long date ranges.
# Increase if you regularly process large backlogs.

MAX_EMAILS_PER_RUN=50

# DEDUP_THRESHOLD: cosine similarity threshold for story-level deduplication.
# Range: 0.0–1.0. Higher = stricter matching (fewer merges).
# Default 0.78 works well for most newsletter mixes; tune after first real run.

DEDUP_THRESHOLD=0.78


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Path to the SQLite database file. The data/ directory is gitignored.
# Change only if you want the database stored elsewhere.

DATABASE_URL=sqlite+aiosqlite:///./data/digest.db


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# HOST: 0.0.0.0 accepts connections on all interfaces (required for Docker).
#       Use 127.0.0.1 to restrict to localhost only.
# PORT: port uvicorn listens on. Change if 8000 is in use.

HOST=0.0.0.0
PORT=8000
